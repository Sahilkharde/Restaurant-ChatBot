<!doctype html>
<html>

<head>
  <meta name="viewport" content="width=device-width" />
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <style>
    td {
      border-bottom: 1px solid gray;
      padding: 20px;
    }

    h2 {
      text-align: center;
    }

    table {
      border: 1px solid black;
    }
  </style>
</head>

<body>
  <table role="presentation" border="0" cellpadding="0" cellspacing="0">
    <tr>
      <td>
        <p>Hello Support Team,</p>
        <p>
          <%= mailDetails.emailBody %>
        </p>
          <h3>User Information:</h3>
        <ul>
          <li><strong>User Type:</strong>&nbsp;<%= mailDetails.userType %>
          </li>
          <li><strong>Name:</strong>&nbsp;<%= mailDetails.name %>
          </li>
          <li><strong>Email:</strong>&nbsp;<%= mailDetails.email %>
          </li>
          <li><strong>Phone:</strong>&nbsp;<%= mailDetails.phone %>
          </li>
          <li><strong>Status:</strong>&nbsp;<%= mailDetails.loginStatus %></li>
         
          <li><strong>Timestamp:</strong>&nbsp;<%= mailDetails.initatedDateTime %> EST
          </li>
        </ul>
         <p>Please log in to the Admin panel to review and take further action if required.</p>

        <p>Thank you for using eNotary On Call.</p>

        <p>Thanks, <br />
          <strong>Team eNotary On Call</strong><br /><br />
          <span class="powered-by"><strong>This is an auto-generated e-mail. Please do not reply.</strong></span>
        </p>
      </td>
    </tr>
  </table>

</body>

</html>